<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Musafir - Discover Campgrounds</title>
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css"
      integrity="sha384-r4NyP46KrjDleawBgD5tp8Y7UzmLA05oM1iAEQ17CSuDqnUK2+k9luXQOfXJCJ4I"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/stylesheets/app.css" />
  </head>

  <body style="background-color: var(--ivory-white);">
    <%- include('partials/navbar') %>

    <!-- Hero Section -->
    <div style="background: linear-gradient(135deg, var(--powder-blue) 0%, var(--sage-green) 100%); padding: 6rem 0; text-align: center;">
      <div class="container">
        <h1 style="color: var(--charcoal-brown); font-size: 4rem; margin-bottom: 1.5rem; font-weight: 700;">Find Your Perfect Campsite</h1>
        <p style="color: var(--charcoal-brown); font-size: 1.4rem; margin-bottom: 2.5rem; opacity: 0.9;">Discover amazing camping destinations across India</p>
        <a href="/campgrounds" class="btn btn-lg" style="padding: 1rem 3rem; font-size: 1.2rem;">Explore Now</a>
      </div>
    </div>

    <!-- Featured Campgrounds -->
    <div class="container mt-5 mb-5">
      <h2 class="text-center mb-5" style="color: var(--dusty-rose); font-size: 2.5rem; font-weight: 600;">Popular Destinations</h2>

      <div class="row g-4">
        <% if (featuredCampgrounds && featuredCampgrounds.length > 0) { %>
          <% featuredCampgrounds.forEach(campground => { %>
            <div class="col-md-4">
              <a href="/campgrounds/<%= campground._id %>" style="text-decoration: none;">
                <div class="card shadow" style="border-radius: 2rem; overflow: hidden; height: 100%; transition: transform 0.3s;" onmouseover="this.style.transform='translateY(-8px)'" onmouseout="this.style.transform='translateY(0)'">
                  <% if (campground.images && campground.images.length > 0) { %>
                    <img src="<%= campground.images[0].url %>" alt="<%= campground.title %>" style="width: 100%; height: 250px; object-fit: cover; display: block;">
                  <% } %>
                  <div class="card-body p-4">
                    <h3 class="card-title" style="color: var(--dusty-rose); font-size: 1.5rem; margin-bottom: 0.5rem;"><%= campground.title %></h3>
                    <p style="color: var(--charcoal-brown); margin-bottom: 1rem;">📍 <%= campground.location %></p>
                    <p style="color: var(--charcoal-brown); font-size: 0.95rem; line-height: 1.6;"><%= campground.description.substring(0, 100) %>...</p>
                    <div style="margin-top: 1rem;">
                      <strong style="color: var(--sage-green); font-size: 1.3rem;">₹<%= campground.price %></strong>
                      <span style="color: var(--charcoal-brown);">/night</span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }); %>
        <% } %>
      </div>

      <div class="text-center mt-5">
        <a href="/campgrounds" class="btn btn-lg me-3" style="padding: 0.8rem 2.5rem;">View All Campgrounds</a>
        <a href="/campgrounds/new" class="btn btn-lg" style="padding: 0.8rem 2.5rem; background-color: var(--sage-green);">Add Your Campsite</a>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script
      src="https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js"
      integrity="sha384-Q6E9RHvbIyZFJoft+2mJbHaEWldlvI9IOYy5n3zV9zzTtmI3UksdQRVvoxMfooAo"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/js/bootstrap.min.js"
      integrity="sha384-oesi62hOLfzrys4LxRF63OJCXdXDipiYWBnvTl9Y9/TRlw5xlKIEHpNyvvDShgf/"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
