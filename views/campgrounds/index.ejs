<% layout('layouts/boilerplate') %>

<div class="explore-page">

  <!-- ============================================================
       CLUSTER MAP — full width hero
       ============================================================ -->
  <div class="explore-map-hero">
    <div class="explore-map-header">
      <h1 class="explore-map-title">Explore Campgrounds</h1>
      <p class="explore-map-sub">
        <%= pagination.totalDocs %> sites across India
        <% if (filters.search) { %>
          · results for "<strong><%= filters.search %></strong>"
        <% } %>
      </p>
    </div>
    <div id="map"></div>
  </div>


  <!-- ============================================================
       TWO-COLUMN: filter sidebar + campground cards
       ============================================================ -->
  <div class="explore-body">

    <!-- LEFT: Filter sidebar -->
    <aside class="explore-sidebar">
      <form action="/campgrounds" method="GET" class="filter-form">

        <div class="filter-header">
          <span class="section-label">FILTERS</span>
          <a href="/campgrounds" class="filter-reset">Reset</a>
        </div>

        <!-- Search -->
        <div class="filter-group">
          <label class="filter-label" for="search">SEARCH</label>
          <div class="filter-input-wrap">
            <svg class="filter-input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              type="text"
              class="filter-input"
              id="search"
              name="search"
              placeholder="Title, location..."
              value="<%= filters.search || '' %>"
            />
          </div>
        </div>

        <!-- Price range -->
        <div class="filter-group">
          <label class="filter-label">PRICE RANGE</label>
          <div class="filter-price-row">
            <input
              type="number"
              class="filter-input filter-input--price"
              name="minPrice"
              placeholder="₹ Min"
              value="<%= filters.minPrice || '' %>"
              min="0"
            />
            <span class="filter-price-sep">—</span>
            <input
              type="number"
              class="filter-input filter-input--price"
              name="maxPrice"
              placeholder="₹ Max"
              value="<%= filters.maxPrice || '' %>"
              min="0"
            />
          </div>
        </div>

        <!-- Sort -->
        <div class="filter-group">
          <label class="filter-label" for="sort">SORT BY</label>
          <select class="filter-select" id="sort" name="sort">
            <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
            <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
            <option value="price-asc" <%= filters.sort === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price-desc" <%= filters.sort === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
          </select>
        </div>

        <button type="submit" class="btn-musafir btn-musafir--primary btn-musafir--full">
          Apply Filters
        </button>

      </form>

      <!-- Add campground CTA -->
      <div class="sidebar-add-cta">
        <p class="sidebar-add-cta__text">Know a great spot?</p>
        <a href="/campgrounds/new" class="btn-musafir btn-musafir--outline btn-musafir--full">
          + Add Campground
        </a>
      </div>

    </aside>

    <!-- RIGHT: Results + cards + pagination -->
    <main class="explore-results">

      <!-- Results count bar -->
      <div class="results-bar">
        <span class="results-count">
          Showing <strong><%= campgrounds.length %></strong> of <strong><%= pagination.totalDocs %></strong> campgrounds
        </span>
      </div>

      <!-- Empty state -->
      <% if (campgrounds.length === 0) { %>
        <div class="explore-empty">
          <p class="explore-empty__title">No campgrounds found</p>
          <p class="explore-empty__sub">Try adjusting your filters or <a href="/campgrounds">clear all</a>.</p>
        </div>

      <% } else { %>

        <!-- Campground cards -->
        <div class="campground-list">
          <% for (let campground of campgrounds) { %>
          <div class="camp-card" data-lat="<%= campground.geometry.coordinates[1] %>" data-lng="<%= campground.geometry.coordinates[0] %>">

            <!-- Image -->
            <div class="camp-card__img">
              <% if (campground.images.length) { %>
                <img src="<%= campground.images[0].url %>" alt="<%= campground.title %>" />
              <% } else { %>
                <img src="https://res.cloudinary.com/dzwjyg2ai/image/upload/v1756312011/musafir/e9z56wsbx8tl1hon1vhm.jpg" alt="<%= campground.title %>" />
              <% } %>
              <!-- Price overlay -->
              <span class="camp-card__price">₹<%= campground.price %><span class="camp-card__price-night">/night</span></span>
            </div>

            <!-- Body -->
            <div class="camp-card__body">
              <div class="camp-card__top">
                <h2 class="camp-card__title"><%= campground.title %></h2>
                <p class="camp-card__location">
                  <span class="loc-icon">⊙</span> <%= campground.location %>
                </p>
                <p class="camp-card__desc">
                  <%= campground.description.substring(0, 160) %><%= campground.description.length > 160 ? '...' : '' %>
                </p>
              </div>

              <div class="camp-card__footer">
                <span class="distance-badge" style="display:none"></span>
                <a class="btn-musafir btn-musafir--primary" href="/campgrounds/<%= campground._id %>">
                  View Details →
                </a>
              </div>
            </div>

          </div>
          <% } %>
        </div>

        <!-- Pagination -->
        <% if (pagination.totalPages > 1) { %>
        <%
          const startPage = Math.max(1, pagination.page - 2);
          const endPage = Math.min(pagination.totalPages, pagination.page + 2);
          const qBase = (filters.search ? '&search=' + filters.search : '') +
                        (filters.minPrice ? '&minPrice=' + filters.minPrice : '') +
                        (filters.maxPrice ? '&maxPrice=' + filters.maxPrice : '') +
                        (filters.sort ? '&sort=' + filters.sort : '');
        %>
        <nav class="pagination-nav" aria-label="Campgrounds pagination">

          <% if (pagination.hasPrevPage) { %>
            <a class="page-btn" href="?page=<%= pagination.prevPage %><%= qBase %>">← Prev</a>
          <% } else { %>
            <span class="page-btn page-btn--disabled">← Prev</span>
          <% } %>

          <div class="page-numbers">
            <% if (startPage > 1) { %>
              <a class="page-btn" href="?page=1<%= qBase %>">1</a>
              <% if (startPage > 2) { %><span class="page-ellipsis">…</span><% } %>
            <% } %>

            <% for (let i = startPage; i <= endPage; i++) { %>
              <a class="page-btn <%= i === pagination.page ? 'page-btn--active' : '' %>"
                 href="?page=<%= i %><%= qBase %>"><%= i %></a>
            <% } %>

            <% if (endPage < pagination.totalPages) { %>
              <% if (endPage < pagination.totalPages - 1) { %><span class="page-ellipsis">…</span><% } %>
              <a class="page-btn" href="?page=<%= pagination.totalPages %><%= qBase %>"><%= pagination.totalPages %></a>
            <% } %>
          </div>

          <% if (pagination.hasNextPage) { %>
            <a class="page-btn" href="?page=<%= pagination.nextPage %><%= qBase %>">Next →</a>
          <% } else { %>
            <span class="page-btn page-btn--disabled">Next →</span>
          <% } %>

        </nav>
        <% } %>

      <% } %>

    </main>
  </div><!-- /explore-body -->

</div><!-- /explore-page -->

<script>
  const maptilerApiKey = '<%- process.env.MAPTILER_API_KEY %>';
  const campgrounds = <%- JSON.stringify(clusterMapData) %>;
</script>
<script src="/javascripts/clusterMap.js"></script>
